#include <winver.h>

#define VER_FILE_VERSION @CMAKE_PROJECT_VERSION_MAJOR@,@CMAKE_PROJECT_VERSION_MINOR@,@CMAKE_PROJECT_VERSION_PATCH@,@CMAKE_PROJECT_VERSION_TWEAK@
#define VER_FILE_VERSION_STR "@CMAKE_PROJECT_VERSION_MAJOR@.@CMAKE_PROJECT_VERSION_MINOR@.@CMAKE_PROJECT_VERSION_PATCH@.@CMAKE_PROJECT_VERSION_TWEAK@"

VS_VERSION_INFO VERSIONINFO
PRODUCTVERSION VER_FILE_VERSION
FILEVERSION VER_FILE_VERSION
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0
FILEOS VOS__WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "040904b0"
		BEGIN
			VALUE "CompanyName", "RocketRide"
			VALUE "LegalCopyright", "Copyright (c) 2026 Aparavi Software AG"
			VALUE "ProductName", "RocketRide Data Intelligence and Automation Engine"
			VALUE "ProductVersion", VER_FILE_VERSION_STR
			VALUE "OriginalFilename", "@ENGINE_NAME@.exe"
			VALUE "InternalName", "@ENGINE_NAME@.exe"
			VALUE "FileVersion", VER_FILE_VERSION_STR
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x409, 1200
	END
END
