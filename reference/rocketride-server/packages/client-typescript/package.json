{
	"name": "rocketride",
	"version": "1.3.0",
	"author": "RocketRide, Inc.",
	"license": "MIT",
	"description": "TypeScript client for RocketRide data processing and AI services",
	"type": "commonjs",
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/types/index.d.ts",
	"bin": {
		"rocketride": "./dist/cli/cli/rocketride.js"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		},
		"./app-sdk": {
			"types": "./dist/types/app-sdk/index.d.ts",
			"import": "./dist/esm/app-sdk/index.js",
			"require": "./dist/cjs/app-sdk/index.js"
		}
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"scripts": {},
	"repository": {
		"type": "git",
		"url": "https://github.com/rocketride-org/rocketride-server.git",
		"directory": "packages/client-typescript"
	},
	"homepage": "https://rocketride.ai/",
	"bugs": {
		"url": "https://github.com/rocketride-org/rocketride-server/issues/"
	},
	"keywords": [
		"rocketride",
		"data-processing",
		"ai",
		"websocket",
		"typescript"
	],
	"dependencies": {
		"commander": "^12.0.0",
		"glob": "^10.5.0"
	},
	"optionalDependencies": {
		"ws": "^8.20.1"
	},
	"devDependencies": {
		"@jest/globals": "^30.4.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.19.41",
		"@types/ws": "^8.18.1",
		"jest": "^29.0.0",
		"jest-jasmine2": "^30.4.2",
		"rimraf": "^5.0.5",
		"ts-jest": "^29.4.10",
		"typescript": "^5.0.0",
		"ws": "^8.20.1"
	}
}
