{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"paths": {
			"shared": ["../../packages/shared-ui/src/index.ts"]
		}
	},
	"include": ["src/providers/views/**/*.ts", "src/providers/views/**/*.tsx", "src/providers/components/**/*.ts", "src/providers/components/**/*.tsx", "src/shared/**/*.ts", "src/assets/**/*.d.ts"]
}
