{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension (with build)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/build/vscode"
			],
			"outFiles": [
				"${workspaceFolder}/build/vscode/**/*.js"
			],
			"sourceMapPathOverrides": {
				"webpack:///./*": "${workspaceFolder}/apps/vscode/*",
				"webpack:///src/*": "${workspaceFolder}/apps/vscode/src/*"
			},
			"debugWebviews": true,
			"preLaunchTask": "build all"
		},
		{
			"name": "Run Extension (no build)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/build/vscode"
			],
			"outFiles": [
				"${workspaceFolder}/build/vscode/**/*.js"
			],
			"sourceMapPathOverrides": {
				"webpack:///./*": "${workspaceFolder}/apps/vscode/*",
				"webpack:///src/*": "${workspaceFolder}/apps/vscode/src/*"
			},
			"debugWebviews": true
		}
	]
}