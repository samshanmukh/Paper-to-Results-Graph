{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"outDir": "../../build/vscode/out",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "Node16",
		"allowSyntheticDefaultImports": true
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"src/**/*.tsx",
		"src/providers/views/**",
		"src/providers/components/**",
		"src/shared/util/mount.ts",
		"src/shared/util/useMessaging.ts"
	]
}

