{
  "name": "Landing.ai Parse + Extract — document to structured fields",
  "description": "Drop a document; Landing.ai parses it to Markdown, then extracts fields defined by a JSON Schema.",
  "components": [
    {
      "id": "dropper_1",
      "provider": "dropper",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "dropper"
      },
      "ui": {
        "position": {
          "x": 40,
          "y": 200
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "landing_ai_parse_1",
      "provider": "landing_ai_parse",
      "config": {
        "default": {
          "model": "dpt-2-latest",
          "region": "production",
          "api_key": ""
        }
      },
      "ui": {
        "position": {
          "x": 280,
          "y": 200
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "tags",
          "from": "dropper_1"
        }
      ]
    },
    {
      "id": "landing_ai_extract_1",
      "provider": "landing_ai_extract",
      "config": {
        "default": {
          "region": "production",
          "strict": false,
          "schema_file": "data:application/json;name=landing_ai_invoice_schema.json;base64,",
          "api_key": ""
        }
      },
      "ui": {
        "position": {
          "x": 520,
          "y": 200
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "text",
          "from": "landing_ai_parse_1"
        }
      ]
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "config": {
        "laneName": "answers"
      },
      "ui": {
        "position": {
          "x": 760,
          "y": 200
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "answers",
          "from": "landing_ai_extract_1"
        }
      ]
    }
  ],
