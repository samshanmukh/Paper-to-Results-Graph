# RocketRide example pipelines — required environment variables.
# Copy to `.env` and fill in the values for the templates you run.

# Anthropic API key — used by agent-llamaindex.pipe, agent-workflow.pipe, llm-benchmark.pipe
ROCKETRIDE_ANTHROPIC_KEY=

# OpenAI API key — used by rag-pipeline.pipe, agent-workflow.pipe, llm-benchmark.pipe
ROCKETRIDE_OPENAI_KEY=

# Gemini API key — used by llm-benchmark.pipe
ROCKETRIDE_GEMINI_KEY=

# Qdrant vector store — used by rag-pipeline.pipe
ROCKETRIDE_QDRANT_HOST=
ROCKETRIDE_COLLECTION_NAME=
