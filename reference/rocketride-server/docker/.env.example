# ---------------------------------------------------------------------------
# .env.example — Environment variables for docker-compose
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# WARNING: Change all passwords before any non-local use!
# ---------------------------------------------------------------------------

# ── Engine ─────────────────────────────────────────────────────────────────
ENGINE_PORT=5565
ROCKETRIDE_LOG_LEVEL=info
ENGINE_CPU_LIMIT=4
ENGINE_MEMORY_LIMIT=4G

# ── PostgreSQL + pgvector ──────────────────────────────────────────────────
POSTGRES_USER=rocketride
# WARNING: Change these before any non-local use
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rocketride
POSTGRES_PORT=5432

# ── Milvus ─────────────────────────────────────────────────────────────────
MILVUS_PORT=19530
MILVUS_GRPC_PORT=9091

# ── MinIO (Milvus object storage) ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
# WARNING: Change these before any non-local use
MINIO_ROOT_PASSWORD=changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── etcd (Milvus metadata) ────────────────────────────────────────────────
ETCD_PORT=2379

# ── ChromaDB ───────────────────────────────────────────────────────────────
CHROMA_PORT=8000
