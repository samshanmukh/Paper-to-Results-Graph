{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Transformer",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "embedding_transformer://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["embedding"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["gpu"],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.embedding_transformer",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "embedding",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A component that transforms text into numerical vector representations using advanced embedding ", "models. It converts input text, ranging from individual words to entire documents, into high-dimensional ", "vectors that capture semantic meaning and relationships. These embeddings enable efficient similarity ", "searches, clustering, and other advanced natural language processing tasks. The text embedder is highly ", "configurable, supporting various pre-trained models and fine-tuning options, ensuring flexibility for ", "different use cases across domains."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "embedding-text.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"documents": ["documents"],
		"questions": ["questions"]
	},
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		// Define the values that will be merged into any profile configuration
		// specified, unless the profile is 'absolute'
		"default": "miniLM",
		// Defines profiles used with the "profile": key
		"profiles": {
			"custom": {
				"title": "Custom model"
			},
			"miniLM": {
				"title": "miniLM  - General use embeddings, good performance",
				"model": "sentence-transformers/multi-qa-MiniLM-L6-cos-v1"
			},
			"miniAll": {
				"title": "miniAll - Another good one",
				"model": "sentence-transformers/all-MiniLM-L6-v2"
			},
			"mpnet": {
				"title": "mpnet   - Yet another good one",
				"model": "sentence-transformers/multi-qa-mpnet-base-cos-v1"
			}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"embedding.model": {
			"type": "string",
			"title": "Model name",
			"minLength": 2,
			"maxLength": 32,
			"description": "Hugging face model to use for embedding"
		},
		"embedding.truncate_dim": {
			"type": "number",
			"title": "Truncate dimensions",
			"description": "Truncate embeddings to this dimensionality (0 = use model default)"
		},
		"embedding.document_prefix": {
			"type": "string",
			"title": "Document prefix",
			"description": "Prefix prepended to document text before encoding (e.g. 'search_document: ', 'passage: ')"
		},
		"embedding.query_prefix": {
			"type": "string",
			"title": "Query prefix",
			"description": "Prefix prepended to query text before encoding (e.g. 'search_query: ', 'query: ')"
		},
		"embedding.custom": {
			"object": "custom",
			"title": "",
			"properties": ["embedding.model", "embedding.truncate_dim", "embedding.document_prefix", "embedding.query_prefix"]
		},
		"embedding.profile": {
			"title": "Model",
			"description": "Embedding model",
			"type": "string",
			"default": "miniLM",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "custom",
					"properties": ["embedding.custom"]
				}
			]
		},
		"embedding.preprocessor": {
			"default": "preprocessor_langchain",
			"providerTitle": "Preprocessor (chunking)",
			"combo": "preprocessor"
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Sentence Transformer",
			"properties": ["embedding.profile"]
		}
	],
	//
	//	Test configuration for automated node testing
	//
	"test": {
		"profiles": ["miniLM"],
		"outputs": ["documents", "questions"],
		"cases": [
			{
				"name": "Embed text chunks",
				"documents": [{ "page_content": "Hello world, this is a test document." }, { "page_content": "Second chunk for embedding." }],
				"expect": {
					"documents": {
						"notEmpty": true
					}
				}
			},
			{
				"name": "Embed single question (flat vector for Qdrant)",
				"questions": "What is the capital of France?",
				"expect": {
					"questions": {
						"notEmpty": true,
						"property": [
							{
								"path": "[0].questions[0].embedding",
								"minLength": 384
							}
						]
					}
				}
			}
		]
	},
	//
	//	Full test configuration - tests all sentence-transformer profiles.
	//	Run via: builder nodes:test-full
	//
	"fulltest": [
		{
			"profiles": ["miniLM", "miniAll", "mpnet"],
			"outputs": ["documents", "questions"],
			"cases": [
				{
					"name": "Embed text chunks",
					"documents": [{ "page_content": "Hello world, this is a test document." }, { "page_content": "Second chunk for embedding." }],
					"expect": {
						"documents": {
							"notEmpty": true
						}
					}
				},
				{
					"name": "Embed single question (flat vector for Qdrant)",
					"questions": "What is the capital of France?",
					"expect": {
						"questions": {
							"notEmpty": true,
							"property": [
								{
									"path": "[0].questions[0].embedding",
									"minLength": 384
								}
							]
						}
					}
				}
			]
		}
	]
}
