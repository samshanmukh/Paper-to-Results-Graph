{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Baidu Qianfan",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "llm_baidu_qianfan://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["llm"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["invoke"],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.llm_baidu_qianfan",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "llm",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A component that connects to Baidu Qianfan ERNIE large language models through ", "Qianfan's OpenAI-compatible chat-completions API. It supports chat-based text generation, ", "question answering, summarization, and Chinese-language enterprise AI workflows with configurable ", "API keys and base URLs."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "baidu-qianfan.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//  Optional:
	//      Rendering hints to the UI which indicate which fields of
	//      the configuration should be used to display information
	//
	"tile": ["Model: ${parameters.llm_baidu_qianfan.profile}"],
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"questions": ["answers"]
	},
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		"default": "ernie-4-5-turbo-128k",
		"profiles": {
			"ernie-4-5-turbo-128k": {
				"title": "ERNIE 4.5 Turbo 128K",
				"model": "ernie-4.5-turbo-128k",
				"modelSource": "provider",
				"modelTotalTokens": 128000,
				"modelOutputTokens": 4096,
				"serverbase": "https://qianfan.baidubce.com/v2",
				"apikey": ""
			},
			"ernie-4-5-turbo-32k": {
				"title": "ERNIE 4.5 Turbo 32K",
				"model": "ernie-4.5-turbo-32k",
				"modelSource": "provider",
				"modelTotalTokens": 32768,
				"modelOutputTokens": 4096,
				"serverbase": "https://qianfan.baidubce.com/v2",
				"apikey": ""
			},
			"ernie-5-0-thinking-preview": {
				"title": "ERNIE 5.0 Thinking Preview",
				"model": "ernie-5.0-thinking-preview",
				"modelSource": "provider",
				"modelTotalTokens": 128000,
				"modelOutputTokens": 8192,
				"serverbase": "https://qianfan.baidubce.com/v2",
				"apikey": ""
			},
			"custom": {
				"title": "Custom",
				"model": "",
				"modelSource": "manual",
				"modelTotalTokens": 32768,
				"modelOutputTokens": 4096,
				"serverbase": "https://qianfan.baidubce.com/v2",
				"apikey": ""
			}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"model": {
			"type": "string",
			"title": "Model",
			"description": "Baidu Qianfan model name"
		},
		"modelTotalTokens": {
			"type": "number",
			"title": "Tokens",
			"description": "Maximum context length in tokens"
		},
		"modelOutputTokens": {
			"type": "number",
			"title": "Output Tokens",
			"description": "Maximum generated tokens"
		},
		"baidu_qianfan.serverbase": {
			"type": "string",
			"title": "Base URL",
			"description": "Qianfan OpenAI-compatible API endpoint.",
			"default": "https://qianfan.baidubce.com/v2",
			"enum": [
				["https://qianfan.baidubce.com/v2", "China (default)"],
				["https://api.baiduqianfan.ai/v1", "International"]
			]
		},
		"baidu_qianfan.ernie-4-5-turbo-128k": {
			"object": "ernie-4-5-turbo-128k",
			"properties": ["llm.cloud.apikey", "baidu_qianfan.serverbase", "llm.cloud.modelSource"]
		},
		"baidu_qianfan.ernie-4-5-turbo-32k": {
			"object": "ernie-4-5-turbo-32k",
			"properties": ["llm.cloud.apikey", "baidu_qianfan.serverbase", "llm.cloud.modelSource"]
		},
		"baidu_qianfan.ernie-5-0-thinking-preview": {
			"object": "ernie-5-0-thinking-preview",
			"properties": ["llm.cloud.apikey", "baidu_qianfan.serverbase", "llm.cloud.modelSource"]
		},
		"baidu_qianfan.custom": {
			"object": "custom",
			"properties": ["model", "modelTotalTokens", "modelOutputTokens", "baidu_qianfan.serverbase", "llm.cloud.apikey", "llm.cloud.modelSource"]
		},
		"baidu_qianfan.profile": {
			"title": "Model",
			"description": "Baidu Qianfan model selection",
			"type": "string",
			"default": "ernie-4-5-turbo-128k",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "ernie-4-5-turbo-128k",
					"properties": ["baidu_qianfan.ernie-4-5-turbo-128k"]
				},
				{
					"value": "ernie-4-5-turbo-32k",
					"properties": ["baidu_qianfan.ernie-4-5-turbo-32k"]
				},
				{
					"value": "ernie-5-0-thinking-preview",
					"properties": ["baidu_qianfan.ernie-5-0-thinking-preview"]
				},
				{
					"value": "custom",
					"properties": ["baidu_qianfan.custom"]
				}
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Baidu Qianfan",
			"properties": ["baidu_qianfan.profile"]
		}
	],
	"test": {
		"profiles": ["ernie-4-5-turbo-128k"],
		"outputs": ["answers"],
		"cases": [
			{
				"name": "LLM returns mock response",
				"text": "What is 2+2?",
				"expect": {
					"answers": {
						"contains": "Mock LLM response"
					}
				}
			}
		]
	}
}
