{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Video Composer",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "video_composer://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["video"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	//		and is optional for most node
	//
	"path": "nodes.video_composer",
	//
	// Required:
	//		The prefix map when added/removed when converting URLs <=> paths
	//
	"prefix": "video_composer",
	//
	//	Optional:
	//		Description of this driver
	//
	"description": ["Stitches a sequence of image frames into an MP4 video using FFmpeg. ", "Place after any image-producing filter to re-encode matched frames into ", "a playable video clip."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "video_composer.svg",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"image": ["video"]
	},
	"input": [
		{
			"lane": "image",
			"description": "Image frames to stitch into a video.",
			"output": [
				{
					"lane": "video",
					"description": "Encoded MP4 video from the input frames."
				}
			]
		}
	],
	//
	//	Optional:
	//		Profile section are configuration options used by the driver
	//		itself
	//
	"preconfig": {
		"default": "standard",
		"profiles": {
			"standard": {
				"title": "Standard quality (H.264, CRF 23)",
				"fps": 1.0,
				"codec": "libx264",
				"crf": 23
			},
			"high": {
				"title": "High quality (H.264, CRF 18)",
				"fps": 1.0,
				"codec": "libx264",
				"crf": 18
			}
		}
	},
	//
	// Optional:
	//		Local field definitions - these define fields only for the
	//		current service
	//
	"fields": {
		"composer.fps": {
			"type": "number",
			"title": "Output frame rate (fps)",
			"description": "Playback speed of the output video. Should match the upstream frame rate.",
			"default": 1.0
		},
		"composer.crf": {
			"type": "number",
			"title": "Quality (CRF)",
			"description": "Constant Rate Factor for H.264. Lower = better quality, larger file. Range 0-51.",
			"default": 23,
			"minimum": 0,
			"maximum": 51
		},
		"composer.standard": {
			"object": "standard",
			"properties": ["composer.fps", "composer.crf"]
		},
		"composer.high": {
			"object": "high",
			"properties": ["composer.fps", "composer.crf"]
		},
		"composer.profile": {
			"title": "Output quality",
			"description": "Video encoding quality preset",
			"type": "string",
			"default": "standard",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "standard",
					"properties": ["composer.standard"]
				},
				{
					"value": "high",
					"properties": ["composer.high"]
				}
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Video Composer",
			"properties": ["composer.profile"]
		}
	]
}
