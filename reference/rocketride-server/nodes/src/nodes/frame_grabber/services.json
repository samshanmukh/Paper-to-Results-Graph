{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Frame Grabber",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "frame_grabber://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["video"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.frame_grabber",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "frame_grabber",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"description": ["A component that extracts frames from video files and outputs them as image data. It ", "supports a variety of video formats and allows users to specify frame extraction ", "intervals (e.g., every 5 seconds or at specific time points). The component processes ", "video content, extracting selected frames as image objects, which can then be passed downstream ", "for further processing, analysis, or display."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "frame_grabber.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"video": ["image", "table", "documents"]
	},
	//
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		// Define the values that will be merged into any profile configuration
		// specified, unless the profile is 'absolute'
		"default": "interval",
		// Defines profiles used with the "profile": key
		"profiles": {
			"interval": {
				"title": "Extract video frames at intervals"
			},
			"transition": {
				"title": "Extract video frames at scene transitions ",
				"percent": 0.4
			},
			"key": {
				"title": "Extract video frames at keyframes"
			}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"grabber.percent": {
			"type": "number",
			"title": "Percentage change for frame",
			"default": 0.4,
			"enum": [
				[0.1, "10%"],
				[0.2, "20%"],
				[0.3, "30%"],
				[0.4, "40%"],
				[0.5, "50%"],
				[0.6, "60%"],
				[0.7, "70%"],
				[0.8, "80%"],
				[0.9, "90%"],
				[1.0, "100%"]
			]
		},
		"grabber.second.interval": {
			"type": "number",
			"title": "Interval (in seconds) between frames",
			"default": 5
		},
		"grabber.start_time": {
			"type": "number",
			"title": "Start time (in seconds) for frame extraction (0=beginning)",
			"default": 0
		},
		"grabber.duration": {
			"type": "number",
			"title": "Duration  (in seconds) for frame extraction (0=end of video)",
			"default": 0
		},
		"grabber.max_frames": {
			"type": "number",
			"title": "Maximum number of frames to extract (0=unlimited)",
			"default": 0
		},
		"grabber.min_scene_gap": {
			"type": "number",
			"title": "Minimum gap between scenes (seconds)",
			"description": "Minimum time gap between extracted frames. Helps reduce burst detections in high-motion segments. Set to 0 to disable.",
			"default": 0,
			"enum": [
				[0, "Disabled"],
				[0.5, "0.5 seconds"],
				[1.0, "1 second"],
				[2.0, "2 seconds"],
				[3.0, "3 seconds"],
				[5.0, "5 seconds"]
			]
		},
		"grabber.interval": {
			"object": "interval",
			"properties": ["grabber.second.interval", "grabber.start_time", "grabber.duration"]
		},
		"grabber.transition": {
			"object": "transition",
			"properties": ["grabber.percent", "grabber.min_scene_gap", "grabber.start_time", "grabber.duration", "grabber.max_frames"]
		},
		"grabber.key": {
			"object": "key",
			"properties": ["grabber.start_time", "grabber.duration", "grabber.max_frames"]
		},
		"grabber.profile": {
			"title": "Frame grabber mode",
			"type": "string",
			"default": "interval",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "interval",
					"properties": ["grabber.interval"]
				},
				{
					"value": "transition",
					"properties": ["grabber.transition"]
				},
				{
					"value": "key",
					"properties": ["grabber.key"]
				}
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Video Frame Grabber",
			"properties": ["grabber.profile"]
		}
	],
	"test": {
		"profiles": ["interval"],
		"outputs": ["image", "table"],
		"cases": [
			{
				"name": "Extract frames at interval",
				"video": "video/BBC - Tear down this wall.mp4",
				"expect": {
					"image": {
						"notEmpty": true
					}
				}
			}
		]
	}
}
