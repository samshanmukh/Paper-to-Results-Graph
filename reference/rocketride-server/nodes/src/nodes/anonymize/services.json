{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Anonymize",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "anonymize_text://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["text"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["gpu"],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.anonymize",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "anonymize_text",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A filter component that ", "identifies and masks sensitive information in text data. It can be configured ", "to detect and redact personally identifiable information (PII), maintaining ", "data privacy while preserving document context.</br>", "</br>", "<b>Note</b>: This component uses AI so 100% accuracy is not guaranteed. It is recommended to review the results."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "util-text.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"text": ["text"]
	},
	//
	//	Test configuration for automated node testing
	//
	"test": {
		"profiles": ["glinerSmall"],
		"cases": [
			{
				"text": "My name is John Smith and my email is john.smith@example.com. Please contact me at 555-123-4567.",
				"expect": {
					"text": {
						"contains": "█"
					}
				}
			}
		]
	},
	//
	//	Full test configuration - tests all available profiles.
	//	Run via: builder nodes:test-full
	//
	"fulltest": [
		{
			"profiles": ["glinerSmall", "glinerMedium", "glinerLarge", "glinerMultiPII", "glinerPIILarge", "glinerMergedLarge", "glinerMulti", "gretelSmall", "gretelLarge", "glinerKo", "glinerIt", "glinerAr", "glinerCommunitySmall", "glinerCommunityMedium", "glinerCommunityLarge", "glinerBiomedSmall", "glinerBiomedLarge"],
			"cases": [
				{
					"text": "My name is John Smith and my email is john.smith@example.com. Please contact me at 555-123-4567.",
					"expect": {
						"text": {
							"contains": "█"
						}
					}
				}
			]
		}
	],
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		"default": "glinerSmall",
		"profiles": {
			"custom": {
				"title": "Custom model",
				"model": "",
				"anonymizeChar": "\u2588",
				"anonymizeAll": false
			},
			"glinerMultiPII": {
