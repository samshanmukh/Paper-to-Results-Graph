		},
		"anonymize.glinerKo": {
			"object": "glinerKo",
			"properties": ["anonymizeChar", "entityTypes", "redactionStyle"]
		},
		"anonymize.glinerIt": {
			"object": "glinerIt",
			"properties": ["anonymizeChar", "entityTypes", "redactionStyle"]
		},
		"anonymize.glinerAr": {
			"object": "glinerAr",
			"properties": ["anonymizeChar", "entityTypes", "redactionStyle"]
		},
		"anonymize.glinerCommunitySmall": {
			"object": "glinerCommunitySmall",
			"properties": ["anonymizeChar", "entityTypes", "redactionStyle"]
		},
		"anonymize.glinerCommunityMedium": {
			"object": "glinerCommunityMedium",
