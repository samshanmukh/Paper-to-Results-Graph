{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Local File System",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "filesys://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["source"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["filesystem", "noremote", "security", "nosaas"],
	//
	// Optional:
	//		Supported actions - if not specified, no actions are supported
	//		engine
	//
	"actions": ["export", "delete", "download"],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	"prefix": "File System",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A source component that reads data from the local file system. It ", "enables ingestion of files and documents stored in directories for ", "further processing within the pipeline. Configurable with path settings ", "and file filters, the component supports flexible access to unstructured ", "data across various formats."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "file-system.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"_source": ["tags"]
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	"fields": {
		"include": {
			"description": "This path defines the paths included for Scan, Index, Classify and OCR. By default, its empty.\n\nFormat for Windows : C:\\foldername (for local filesystem) or \\\\file.core.net\\foldername (for shared folders)\n\nFormat for Linux : /file.core.net/foldername"
		},
		"exclude": {
			"description": "This path defines the paths excluded for Scan, Index, Classify and OCR. By default, its empty.\n\nFormat for Windows : C:\\foldername (for local filesystem) or \\\\file.core.net\\foldername (for shared folders)\n\nFormat for Linux : /file.core.net/foldername"
		},
		"excludeExternalDrives": {
			"title": "Exclude external drives",
			"type": "boolean",
			"default": true
		},
		"excludeEnableGlobal": {
			"title": "Exclude typical OS files and directories",
			"type": "boolean",
			"default": true
		},
		"excludeSymlinks": {
			"title": "Exclude symlinks",
			"type": "boolean",
			"default": true
		},
		"filesys.source.parameters": {
			"section": "parameters",
			"title": "Parameters",
			"properties": ["excludeExternalDrives", "excludeEnableGlobal", "excludeSymlinks"]
		},
		"Pipe.include": {
			"description": "Example Path: /Users/usr/Documents/product-images/*"
		},
		"Pipe.exclude": {
			"description": "Example Path: /Users/usr/Documents/product-images/*"
		},
		"Pipe.filesys.source.parameters": {
			"section": "parameters",
			"properties": ["excludeExternalDrives", "excludeEnableGlobal", "excludeSymlinks"]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		may be specified, or both, but at least one is required
	"shape": [
		{
			"section": "Source",
			"title": "File System",
			"properties": ["type", "actions", "source.mode", "filesys.source.parameters", "include", "exclude", "estimation"]
		},
		{
			"section": "Pipe",
			"title": "File System",
			"properties": ["type", "actions", "source.mode", "Pipe.filesys.source.parameters", "Pipe.include", "Pipe.exclude"]
		}
	]
}
