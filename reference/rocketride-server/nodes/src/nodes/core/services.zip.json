{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "ZIP Creation",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "zip://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["target"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["internal"],
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["An internal target component that collects processed content and packages it into a ZIP archive available for export or download."],
	//
	// Optional:
	//		Supported actions - if not specified, no actions are supported
	//		engine
	//
	"actions": ["export", "delete", "download"],
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Zip",
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"zip.target.parameters": {
			"object": "parameters",
			"properties": ["storePath", "url"]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Target",
			"title": "Zip Stream",
			"properties": ["type", "zip.target.parameters"]
		}
	]
}
