{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Video",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "embedding_video://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["embedding"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["gpu", "experimental"],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual pyhsical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.embedding_video",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "embedding",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A processing component that generates vector embeddings from video content ", "by extracting frames at configurable intervals and encoding them using ", "vision models such as CLIP. It transforms visual features from video frames ", "into numerical representations that capture the semantic and structural ", "characteristics of the video. These embeddings enable similarity search, ", "clustering, and integration into multimodal RAG workflows. Ideal for use ", "cases involving video retrieval, semantic search, and content understanding."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "embedding-video.svg",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"video": ["documents"]
	},
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		// Define the values that will be merged into any profile configuration
		// specified, unless the profile is 'absolute'
		"default": "openai-patch16",
		// Defines profiles used with the "profile": key
		"profiles": {
			"custom": {
				"title": "Custom model"
			},
			"openai-patch16": {
				"title": "OpenAI CLIP - 16x16 - good performance, lower memory",
				"model": "openai/clip-vit-base-patch16"
			},
			"openai-patch32": {
				"title": "OpenAI CLIP - 32x32 - lower performance, better recognition",
				"model": "openai/clip-vit-base-patch32"
			},
			"google16x224": {
				"title": "Google ViT - 16x16 - fast, accurate, general-purpose",
				"model": "google/vit-base-patch16-224"
			}
		}
	},
	//
	// Optional:
	//		Local fields defintions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"embedding.model": {
			"type": "string",
			"title": "Model name",
			"minLength": 2,
			"maxLength": 256,
			"description": "Hugging Face model to use for frame embedding"
		},
		"embedding.custom": {
			"object": "custom",
			"title": "",
			"properties": ["embedding.model"]
		},
		"embedding.profile": {
			"title": "Model",
			"description": "Embedding model for video frames",
			"type": "string",
			"default": "openai-patch16",
			"enum": ["*>preconfig.profiles.*.title"],
			"conditional": [
				{
					"value": "custom",
					"properties": ["embedding.custom"]
				}
			]
		},
		"embedding.interval": {
			"type": "number",
			"title": "Interval (in seconds) between frames",
			"description": "Time in seconds between extracted frames",
			"default": 5
		},
		"embedding.max_frames": {
			"type": "number",
			"title": "Maximum number of frames to extract (0=unlimited)",
			"description": "Limit the total number of frames extracted from the video. Set to 0 for unlimited.",
			"default": 50
		},
		"embedding.start_time": {
			"type": "number",
			"title": "Start time (in seconds) for frame extraction (0=beginning)",
			"default": 0
		},
		"embedding.duration": {
			"type": "number",
			"title": "Duration (in seconds) for frame extraction (0=end of video)",
			"default": 0
		},
		"embedding.maxVideoSizeMB": {
			"type": "number",
			"title": "Maximum video file size (MB)",
			"description": "Maximum allowed video file size in megabytes. Videos exceeding this limit will be rejected.",
			"default": 500
		},
		"embedding.extraction": {
			"object": "extraction",
			"title": "Frame Extraction",
			"properties": ["embedding.interval", "embedding.max_frames", "embedding.start_time", "embedding.duration", "embedding.maxVideoSizeMB"]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Video Embedding",
			"properties": ["embedding.profile", "embedding.extraction"]
		}
	],
	//
	//	Test configuration for automated node testing
	//
	"test": {
		"profiles": ["openai-patch16"],
		"outputs": ["documents"],
		"timeout": 180,
		"cases": [
			{
				"name": "Embed video frames",
				"video": "video/BBC - Tear down this wall.mp4",
				"expect": {
					"documents": {
						"notEmpty": true,
						"property": [
							{
								"path": "[0].embedding",
								"minLength": 384
							}
						]
					}
				}
			}
		]
	}
}
