{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "General Text",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "preprocessor_langchain://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["preprocessor"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.preprocessor_langchain",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Preprocessor",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A preprocessing component that segments large bodies of text into intelligently sized ", "chunks for downstream processing. It recursively splits content based on a hierarchy ", "of separators (such as paragraphs, sentences, or words) preserving context while ensuring ", "each chunk meets token or length constraints. This enables efficient handling of lengthy ", "documents in workflows like embedding, retrieval, or LLM-based generation. Ideal for ", "preparing content for language models where context length and coherence are critical."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "preprocessor-text.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//  Optional:
	//      Rendering hints to the UI which indicate which fields of
	//      the configuration should be used to display information
	"tile": ["Mode: ${parameters.preprocessor_langchain.profile}"],
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"table": ["documents"],
		"text": ["documents"]
	},
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		// Define the values that will be merged into any profile configuration
		// specified, unless the profile is 'absolute'
		"default": "default",
		// Defines profiles used with the "profile": key
		"profiles": {
			"default": {
				"splitter": "RecursiveCharacterTextSplitter",
				"mode": "strlen",
				"strlen": 512
			},
			"recursive": {
				"splitter": "RecursiveCharacterTextSplitter",
				"separators": "",
				"mode": "strlen",
				"strlen": 512
			},
			"character": {
				"splitter": "CharacterTextSplitter",
				"separator": "",
				"mode": "strlen",
				"strlen": 512
			},
			"markdown": {
				"splitter": "MarkdownTextSplitter",
				"mode": "strlen",
				"strlen": 512
			},
			"latex": {
				"splitter": "LatexTextSplitter",
				"mode": "strlen",
				"strlen": 512
			},
			"nltk": {
				"splitter": "NLTKTextSplitter",
				"mode": "strlen",
				"strlen": 512
			},
			"spacy": {
				"splitter": "SpacyTextSplitter",
				"model": "en_core_web_sm",
				"pipeline": "",
				"mode": "strlen",
				"strlen": 512
			},
			"custom": {
				"splitter": "RecursiveCharacterTextSplitter",
				"mode": "strlen",
				"strlen": 512
			}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		//
		// String length
		//
		"langchain.splitter.strlen": {
			"type": "number",
			"title": "String length",
			"default": 512
		},
		"langchain.splitter.tokens": {
			"type": "number",
			"title": "Number of tokens",
			"default": 512
		},
		"langchain.splitter.mode": {
			"type": "string",
			"title": "Split by",
			"default": "strlen",
			"enum": [
				["strlen", "String length"],
				["tokens", "Estimated tokens"]
			],
			"conditional": [
				{
					"value": "strlen",
					"properties": ["langchain.splitter.strlen"]
				},
				{
					"value": "tokens",
					"properties": ["langchain.splitter.tokens"]
				}
			]
		},
		//
		// Default - RecursiveCharacterTextSplitter
		//
		"langchain.splitter.default.splitter": {
			"type": "string",
			"default": "RecursiveCharacterTextSplitter",
			"const": "RecursiveCharacterTextSplitter"
		},
		"langchain.splitter.default": {
			"object": "default",
			"properties": ["langchain.splitter.default.splitter", "langchain.splitter.mode"]
		},
		//
		// RecursiveCharacterTextSplitter
		//
		"langchain.splitter.recursive.separators": {
			"type": "string",
			"title": "Split separators",
			"default": "'\\n\\n', '\\n', ' ', ''"
		},
		"langchain.splitter.recursive.splitter": {
			"type": "string",
			"default": "RecursiveCharacterTextSplitter",
			"const": "RecursiveCharacterTextSplitter"
		},
		"langchain.splitter.recursive": {
			"object": "recursive",
			"properties": ["langchain.splitter.recursive.splitter", "langchain.splitter.recursive.separators", "langchain.splitter.mode"]
		},
		//
		// CharacterTextSplitter
		//
		"langchain.splitter.character.separator": {
			"type": "string",
			"title": "Split separator",
			"default": "\"\\n\""
		},
		"langchain.splitter.character.splitter": {
			"type": "string",
			"default": "CharacterTextSplitter",
			"const": "CharacterTextSplitter"
		},
		"langchain.splitter.character": {
			"object": "character",
			"properties": ["langchain.splitter.character.splitter", "langchain.splitter.character.separator", "langchain.splitter.mode"]
		},
		//
		// MarkdownTextSplitter
		//
		"langchain.splitter.markdown.splitter": {
			"type": "string",
			"default": "MarkdownTextSplitter",
			"const": "MarkdownTextSplitter"
		},
		"langchain.splitter.markdown": {
			"object": "markdown",
			"properties": ["langchain.splitter.markdown.splitter", "langchain.splitter.mode"]
		},
		//
		// LatexTextSplitter
		//
		"langchain.splitter.latex.splitter": {
			"type": "string",
			"default": "LatexTextSplitter",
			"const": "LatexTextSplitter"
		},
		"langchain.splitter.latex": {
			"object": "latex",
			"properties": ["langchain.splitter.latex.splitter", "langchain.splitter.mode"]
		},
		//
		// NLTKTextSplitter
		//
		"langchain.splitter.nltk.splitter": {
			"type": "string",
			"default": "NLTKTextSplitter",
			"const": "NLTKTextSplitter"
		},
		"langchain.splitter.nltk": {
			"object": "nltk",
			"properties": ["langchain.splitter.nltk.splitter", "langchain.splitter.mode"]
		},
		//
		// SpacyTextSplitter
		//
		"langchain.splitter.spacy.splitter": {
			"type": "string",
			"default": "SpacyTextSplitter",
			"const": "SpacyTextSplitter"
		},
		"langchain.splitter.spacy.model": {
			"type": "string",
			"title": "Model",
			"default": "en_core_web_sm",
			"enum": [
				["en_core_web_sm", "English: Small, Basic NLP (POS tagging, NER, Parsing)"],
				["en_core_web_md", "English: Medium, Includes word vectors"],
				["en_core_web_lg", "English: Large, Larger word vectors"],
				["en_core_web_trf", "English: Transformer, Best accuracy, slower, uses transformers"],
				["de_core_news_sm", "German: Small, Basic NLP"],
				["de_core_news_md", "German: Medium, Includes word vectors"],
				["de_core_news_lg", "German: Large, Larger word vectors"],
				["fr_core_news_sm", "French: Small, Basic NLP"],
				["fr_core_news_md", "French: Medium, Includes word vectors"],
				["fr_core_news_lg", "French: Large, Larger word vectors"],
				["es_core_news_sm", "Spanish: Small, Basic NLP"],
				["es_core_news_md", "Spanish: Medium, Includes word vectors"],
				["es_core_news_lg", "Spanish: Large, Larger word vectors"]
			]
		},
		"langchain.splitter.spacy": {
			"object": "spacy",
			"properties": ["langchain.splitter.spacy.splitter", "langchain.splitter.spacy.model", "langchain.splitter.mode"]
		},
		//
		// Custom
		//
		"langchain.splitter.custom.splitter": {
			"type": "string",
			"default": "RecursiveCharacterTextSplitter",
			"const": "RecursiveCharacterTextSplitter",
			"title": "Splitter class name"
		},
		"langchain.splitter.custom": {
			"object": "custom",
			"properties": ["langchain.splitter.custom.splitter", "langchain.splitter.mode"]
		},
		//
		// Selects the text splitter
		//
		"langchain.splitter.profile": {
			"type": "string",
			"title": "Text splitter",
			"default": "default",
			"enum": [
				["default", "Default Text Splitter - General-purpose, best balance of structure & size"],
				["recursive", "Recursive Character Text Splitter - General-purpose, best balance of structure & size"],
				["character", "Character Text Splitter - Simple splitting with a fixed separator"],
				["markdown", "Markdown Text Splitter - Parsing structured markdown files"],
				["latex", "Latex Text Splitter - Splitting scientific documents"],
				["nltk", "NLTK Text Splitter - Sentence-based splitting using NLTK"],
				["spacy", "Spacy Text Splitter - More advanced NLP-based sentence splitting"],
				["custom", "Custom splitter"]
			],
			"conditional": [
				{
					"value": "default",
					"properties": ["langchain.splitter.default"]
				},
				{
					"value": "recursive",
					"properties": ["langchain.splitter.recursive"]
				},
				{
					"value": "character",
					"properties": ["langchain.splitter.character"]
				},
				{
					"value": "markdown",
					"properties": ["langchain.splitter.markdown"]
				},
				{
					"value": "latex",
					"properties": ["langchain.splitter.latex"]
				},
				{
					"value": "nltk",
					"properties": ["langchain.splitter.nltk"]
				},
				{
					"value": "spacy",
					"properties": ["langchain.splitter.spacy"]
				},
				{
					"value": "custom",
					"properties": ["langchain.splitter.custom"]
				}
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "General Text",
			"properties": ["langchain.splitter.profile"]
		}
	],
	"test": {
		"profiles": ["default"],
		"outputs": ["documents"],
		"cases": [
			{
				"name": "Split text into chunks",
				"text": "First paragraph with some content.\n\nSecond paragraph separated by newlines.\n\nThird paragraph for chunking.",
				"expect": {
					"documents": {
						"notEmpty": true
					}
				}
			}
		]
	}
}
