{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Summarization: LLM",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "summarization://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["text"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.summarization",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "Summarization",
	//
	// Optional:
	//		Description to of this driver
	//
	"description": ["A processing component that analyzes document content to extract concise ", "summaries, key points, and named entities. Designed to enhance understanding ", "and downstream utility, it supports unstructured text and delivers structured ", "insights for indexing, search, or display. Ideal for distilling key information ", "from large volumes of content."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "summaries.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//  Optional:
	//      Rendering hints to the UI which indicate which fields of
	//      the configuration should be used to display information
	"tile": [],
	//
	// Optional:
	//		Defines the invoke connections that may/must be connected
	// 		which are utilized by this driver
	//
	"invoke": {
		"llm": {
			"description": "LLM to use to summarize the document",
			"min": 1
		}
	},
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"text": ["text", "documents"]
	},
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		// Define the values that will be merged into any profile configuration
		// specified, unless the profile is 'absolute'
		"default": "default",
		// Defines profiles used with the "profile": key
		"profiles": {
			"default": {}
		}
	},
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"summarization.numberOfSummaries": {
			"type": "number",
			"title": "Number of chunks to summarize after the document is split",
			"optional": false
		},
		"summarization.numberOfSummaryWords": {
			"type": "number",
			"title": "Number of words in each summary. Set to 0 to disable summaries.",
			"optional": false
		},
		"summarization.numberOfKeyPointWords": {
			"type": "number",
			"title": "Number of words in each key point. Set to 0 to disable key points.",
			"optional": false
		},
		"summarization.numberOfEntities": {
			"type": "number",
			"title": "Number of entities to extract from the document. Set to 0 to disable entity extraction.",
			"optional": false
		},
		"summarization.default": {
			"object": "default",
			"properties": ["summarization.numberOfSummaries", "summarization.numberOfSummaryWords", "summarization.numberOfKeyPointWords", "summarization.numberOfEntities"]
		},
		"summarization.profile": {
			"hidden": true,
			"type": "string",
			"default": "default",
			"enum": [["default", "Default"]],
			"conditional": [
				{
					"value": "default",
					"properties": ["summarization.default"]
				}
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Summarization",
			"properties": ["summarization.profile"]
		}
	]
}
