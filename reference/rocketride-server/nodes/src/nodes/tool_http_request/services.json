{
	"title": "HTTP Request",
	"protocol": "tool_http_request://",
	"classType": ["tool"],
	"capabilities": ["invoke"],
	"register": "filter",
	"node": "python",
	"path": "nodes.tool_http_request",
	"prefix": "http",
	"icon": "http.svg",
	"documentation": "https://docs.rocketride.org",
	"description": ["Makes HTTP requests to any API endpoint, like curl for agents.", "The agent provides the full request (method, URL, headers, body, auth).", "The node enforces security guardrails: only whitelisted URLs and enabled HTTP methods are permitted."],
	"tile": ["Tool: ${parameters.http_request.serverName}.http_request"],
	"lanes": {},
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {
				"title": "Default",
				"serverName": "http"
			}
		}
	},
	"fields": {
		"http_request.serverName": {
			"hidden": true,
			"type": "string",
			"title": "Server name",
			"description": "Namespace prefix for the tool: <serverName>.http_request",
			"default": "http"
		},

		"http_request.allowGET": {
			"type": "boolean",
			"title": "GET",
			"default": true,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},
		"http_request.allowPOST": {
			"type": "boolean",
			"title": "POST",
			"default": true,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},
		"http_request.allowPUT": {
			"type": "boolean",
			"title": "PUT",
			"default": true,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},
		"http_request.allowPATCH": {
			"type": "boolean",
			"title": "PATCH",
			"default": true,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},
		"http_request.allowDELETE": {
			"type": "boolean",
			"title": "DELETE",
			"default": true,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},
		"http_request.allowHEAD": {
			"type": "boolean",
			"title": "HEAD",
			"default": false,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},
		"http_request.allowOPTIONS": {
			"type": "boolean",
			"title": "OPTIONS",
			"default": false,
			"enum": [
				[true, "Yes"],
				[false, "No"]
			]
		},

		"http_request.whitelistPattern": {
			"type": "string",
			"title": "URL Pattern (regex)",
			"default": ""
		},
		"http_request.urlWhitelist": {
			"title": "URL Whitelist",
			"description": "Regex patterns for allowed URLs. A request URL must match at least one pattern. If empty, all URLs are allowed.",
			"type": "array",
			"optional": true,
			"minItems": 0,
			"items": {
				"type": "object",
				"properties": ["http_request.whitelistPattern"]
			}
		},

		"http_request.rateLimitPerSecond": {
			"type": "number",
			"title": "Max requests per second",
			"description": "Maximum number of HTTP requests allowed per second. Uses a token-bucket algorithm for smooth enforcement.",
			"default": 10
		},
		"http_request.rateLimitPerMinute": {
			"type": "number",
			"title": "Max requests per minute",
			"description": "Maximum number of HTTP requests allowed per minute. Provides a broader throttle beyond the per-second limit.",
			"default": 100
		},
		"http_request.maxConcurrentRequests": {
			"type": "number",
			"title": "Max concurrent requests",
			"description": "Maximum number of HTTP requests that can be in-flight simultaneously.",
			"default": 5
		}
	},
	"shape": [
		{
			"section": "Pipe",
			"title": "HTTP Request",
			"properties": ["type", "http_request.allowGET", "http_request.allowPOST", "http_request.allowPUT", "http_request.allowPATCH", "http_request.allowDELETE", "http_request.allowHEAD", "http_request.allowOPTIONS", "http_request.urlWhitelist", "http_request.rateLimitPerSecond", "http_request.rateLimitPerMinute", "http_request.maxConcurrentRequests"]
		}
	]
}
