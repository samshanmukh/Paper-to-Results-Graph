{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Landing.ai Parse",

	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "landing_ai_parse://",

	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["data"],

	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine. "experimental" marks this as a new node; no "gpu" because all
	//		compute happens remotely on Landing.ai.
	//
	"capabilities": [],

	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",

	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",

	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	//		and is optional for most node
	//
	"path": "nodes.landing_ai.parse",

	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "landing_ai_parse",

	//
	// Optional:
	//		Description of this driver
	//
	"description": ["Parses documents with Landing.ai Agentic Document Extraction (ADE), ", "extracting clean Markdown text and structured tables from PDFs, images, ", "and spreadsheets using the DPT-2 model."],

	//
	// Optional:
	//		The icon is the icon to display in the UI for this node
	//
	"icon": "landing_ai.svg",
	"documentation": "https://docs.landing.ai/ade/ade-python",

	//
	// Required:
	//		Defines the input and output data types for the node
	//
	"lanes": {
		"tags": ["text", "table"]
	},

	//
	// Required:
	//		Defines the fields (shape) of the service shown in the side panel
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Landing.ai Parse",
			"properties": ["landing_ai_parse.default"]
		}
	],

	//
	// Required:
	//		Defines the fields that are available in the UI and for config
	//
	"fields": {
		"landing_ai_parse.api_key": {
			"type": "string",
			"title": "API Key",
			"description": "Your Landing.ai ADE API key. Falls back to the ROCKETRIDE_LANDING_AI_KEY environment variable when left blank.",
			"secure": true,
			"ui": {
				"ui:widget": "ApiKeyWidget"
			}
		},
		"landing_ai_parse.model": {
			"type": "string",
			"title": "Model",
			"description": "ADE parse model to use.",
			"default": "dpt-2-latest",
			"enum": [
				["dpt-2-latest", "DPT-2 (latest)"]
			]
		},
		"landing_ai_parse.region": {
			"type": "string",
			"title": "Region",
			"description": "Which Landing.ai deployment to call. Use EU for the eu-west-1 data-residency endpoint.",
			"default": "production",
			"enum": [
				["production", "US (production)"],
				["eu", "EU (eu-west-1)"]
			]
		},
		"landing_ai_parse.default": {
			"object": "default",
			"properties": ["landing_ai_parse.api_key", "landing_ai_parse.model", "landing_ai_parse.region"]
		}
	},

	//
	// Optional:
	//		Predefined configurations for common use cases
	//
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {
				"model": "dpt-2-latest",
				"region": "production"
			}
		}
	},
	"required": []
}
