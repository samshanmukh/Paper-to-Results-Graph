{
	"title": "Chart (Chart.js)",
	"protocol": "tool_chartjs://",
	"classType": ["tool"],
	"capabilities": ["invoke"],
	"register": "filter",
	"node": "python",
	"path": "nodes.tool_chartjs",
	"prefix": "chartjs",
	"icon": "chartjs.svg",
	"documentation": "https://docs.rocketride.org",
	"description": ["Generates Chart.js v4 chart configurations from data using the pipeline LLM.", "The agent provides raw data and an optional chart type or description.", "Returns a ```chartjs fenced code block ready for rendering in the chat UI."],
	"tile": ["Tool: ${parameters.tool_chartjs.serverName}.generate_chart"],
	"invoke": {
		"llm": {
			"description": "LLM used to generate Chart.js configurations from data",
			"min": 1
		}
	},
	"lanes": {},
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {
				"title": "Default",
				"serverName": "chartjs"
			}
		}
	},
	"fields": {
		"tool_chartjs.serverName": {
			"hidden": true,
			"type": "string",
			"title": "Server name",
			"description": "Namespace prefix for the tool: <serverName>.generate_chart",
			"default": "chartjs"
		}
	},
	"shape": [
		{
			"section": "Pipe",
			"title": "Chart (Chart.js)",
			"properties": ["type"]
		}
	]
}
