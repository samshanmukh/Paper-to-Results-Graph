{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Transcribe",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "audio_transcribe://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["audio"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": [],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "filter",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	// 		and is optional for most node
	//
	"path": "nodes.audio_transcribe",
	//
	// Required:
	//		The prefix map when added/removed when convertting URLs <=> paths
	//
	"prefix": "audio_transcribe",
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"description": ["The Audio transcribe component recieves audio or video and transcribes into text."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "audio-transcribe.svg",
	"documentation": "https://docs.rocketride.org",
	//
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"audio": ["text"],
		"video": ["text"]
	},
	//
	//
	//	Optional:
	//		Profile section are configuration optoins used by the driver
	//		itself
	//
	"preconfig": {
		// Define the values that will be merged into any profile configuration
		// specified, unless the profile is 'absolute'
		"default": "default",
		// Defines profiles used with the "profile": key
		"profiles": {
			"default": {
				"mode": "base",
				"language": "en",
				"silence_threshold": 0.25,
				"min_seconds": 240,
				"max_seconds": 300,
				"vad_level": 1
			},
			"tiny": {
				"mode": "tiny",
				"language": "en",
				"silence_threshold": 0.25,
				"min_seconds": 240,
				"max_seconds": 300,
				"vad_level": 1
			},
			"base": {
				"mode": "base",
				"language": "en",
				"silence_threshold": 0.25,
				"min_seconds": 240,
				"max_seconds": 300,
				"vad_level": 1
			},
			"small": {
				"mode": "small",
				"language": "en",
				"silence_threshold": 0.25,
				"min_seconds": 240,
				"max_seconds": 300,
				"vad_level": 1
			},
			"medium": {
				"mode": "medium",
				"language": "en",
				"silence_threshold": 0.25,
				"min_seconds": 240,
				"max_seconds": 300,
				"vad_level": 1
			},
			"large-v3": {
				"mode": "large-v3",
				"language": "en",
				"silence_threshold": 0.25,
				"min_seconds": 240,
				"max_seconds": 300,
				"vad_level": 1
			}
		}
	},
	//
	// Optional:
	//		Test configuration for automated node testing
	//
	"test": {
		"profiles": ["default"],
		"cases": [
			{
				"video": "video/BBC - Tear down this wall.mp4",
				"expect": {
					"text": {
						"beginsWith": "Where East meets West in the divided",
						"contains": "Mr Gorbachev, open this gate.\nMr Gorbachev, tear down this wall.\n",
						"endsWith": "as many again were arrested.\n\n\n"
					}
				}
			}
		]
	},
	//
	//	Full test configuration - tests all Whisper model sizes.
	//	Run via: builder nodes:test-full
	//
	"fulltest": [
		{
			"profiles": ["tiny", "base", "small", "medium", "large-v3"],
			"outputs": ["text"],
			"timeout": 300,
			"cases": [
				{
					"video": "video/BBC - Tear down this wall.mp4",
					"expect": {
						"text": {
							"contains": "Mr Gorbachev, tear down this wall."
						}
					}
				}
			]
		}
	],
	//
	// Optional:
	//		Local fields definitions - these define fields only for the
	//		current service. You may specify them here, or directly
	//		in the shape
	//
	"fields": {
		"transcribe.model": {
			"type": "string",
			"title": "Model",
			"description": "The Whisper model to use for transcription",
			"enum": [
				["tiny", "Tiny - Faster, least acccurate"],
				["base", "Base - Fast, low accuracy"],
				["small", "Small - Medium, medium accuracy"],
				["medium", "Medium - Slower, high accuracy"],
				["large-v3", "Large v3 - Slowest, Highest accuracy"]
			],
			"default": "base"
		},
		"transcribe.silence_threshold": {
			"type": "number",
			"title": "Silence Threshold",
			"description": "The silence threshold to detect silence in speech (in seconds)",
			"default": 0.25
		},
		"transcribe.min_seconds": {
			"type": "number",
			"title": "Minimum Seconds",
			"description": "The minimum seconds of audio to process in a batch and looking for silence",
			"default": 240
		},
		"transcribe.max_seconds": {
			"type": "number",
			"title": "Maximum Seconds",
			"description": "The maximum seconds of audio to buffer to process",
			"default": 300
		},
		"transcribe.vad_level": {
			"type": "number",
			"title": "VAD Level",
			"description": "The VAD level to use for silence detection (0-3)",
			"default": 1,
			"enum": [
				[0, "Most permissive - detects the most audio as speech (risk: includes noise"],
				[1, "Slightly more aggressive - skips minor background noise."],
				[2, "Balanced - moderate filtering of non-speech (default in many tools)."],
				[3, "Most aggressive - filters aggressively, may cut off quiet or short speech."]
			]
		},
		"transcribe.default": {
			"object": "default",
			"properties": ["transcribe.model", "transcribe.silence_threshold", "transcribe.min_seconds", "transcribe.max_seconds", "transcribe.vad_level"]
		},
		"transcribe.profile": {
			"hidden": true,
			"type": "string",
			"default": "default",
			"enum": [["default", "Default"]],
			"conditional": [
				{
					"value": "default",
					"properties": ["transcribe.default"]
				}
			]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service. Either source or target
	//		map be specified, or both, but at least one is required
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Transcribe",
			"properties": ["transcribe.profile"]
		}
	]
}
