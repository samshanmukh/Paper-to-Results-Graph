{
	//
	// Required:
	//		The displayable name of this node
	//
	"title": "Telegram Bot",
	//
	// Required:
	//		The protocol is the endpoint protocol
	//
	"protocol": "telegram://",
	//
	// Required:
	//		Class type of the node - what it does
	//
	"classType": ["source"],
	//
	// Required:
	//		Capabilities are flags that change the behavior of the underlying
	//		engine
	//
	"capabilities": ["noinclude"],
	//
	// Optional:
	//		Register is either filter, endpoint or ignored if not specified. If the
	//		type is specified, a factory is registered of that given type
	//
	"register": "endpoint",
	//
	// Optional:
	//		The node is the actual physical node to instantiate - if
	//		not specified, the protocol will be used
	//
	"node": "python",
	//
	// Optional:
	//		The path is the executable/script code - it is node dependent
	//		and is optional for most nodes
	//
	"path": "nodes.telegram",
	//
	// Required:
	//		The prefix map when added/removed when converting URLs <=> paths
	//
	"prefix": "Telegram",
	//
	// Optional:
	//		Description of this driver
	//
	"description": ["A Telegram Bot source node that receives messages from users via the Telegram Bot API. ", "Supports text messages and media files (images, audio, voice, video, documents). ", "Each message type is routed to the appropriate pipeline lane. ", "Pipeline responses are automatically sent back as replies to the sender. ", "Supports both long polling (for local/private setups) and webhook (for production)."],
	//
	// Optional:
	//	  The icon is the icon to display in the UI for this node
	//
	"icon": "telegram.svg",
	//
	// Optional:
	//	 The tile is the displayable name of this node
	//
	"tile": ["Mode: ${parameters.telegram.mode}"],
	//
	//	Optional:
	//		As a pipe component, define what this pipe component takes
	//		and what it produces
	//
	"lanes": {
		"_source": ["text", "image", "audio", "video", "tags"]
	},
	//
	//	Optional:
	//		Profile section are configuration options used by the driver itself
	//
	"preconfig": {
		"default": "default",
		"profiles": {
			"default": {}
		}
	},
	//
	// Optional:
	//		Local field definitions - these define fields only for the
	//		current service.
	//
	"fields": {
		"telegram.botToken": {
			"type": "string",
			"title": "Bot Token",
			"description": "Telegram bot token from @BotFather (e.g. 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)",
			"optional": false,
			"secure": true,
			"ui": {
				"ui:widget": "ApiKeyWidget"
			}
		},
		"telegram.mode": {
			"type": "string",
			"title": "Connection Mode",
			"description": "Polling works anywhere without a public URL. Webhook requires a public HTTPS endpoint.",
			"enum": ["polling", "webhook"],
			"default": "polling",
			"conditional": [
				{
					"value": "webhook",
					"properties": ["telegram.webhookUrl"]
				}
			]
		},
		"telegram.webhookUrl": {
			"type": "string",
			"title": "Webhook URL",
			"description": "Public HTTPS URL Telegram will POST updates to (e.g. https://your-server.com/telegram/webhook). Required for webhook mode.",
			"optional": true
		},
		"Pipe.source.parameters": {
			"section": "parameters",
			"title": "Bot Configuration",
			"properties": ["telegram.botToken", "telegram.mode"]
		}
	},
	//
	// Required:
	//		Defines the fields (shape) of the service.
	//
	"shape": [
		{
			"section": "Pipe",
			"title": "Telegram Bot",
			"properties": ["type", "Pipe.source.parameters"]
		}
	]
}
