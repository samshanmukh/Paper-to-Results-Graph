# Neo4j Aura
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# Butterbase (account API key + apps)
BUTTERBASE_API_KEY=bb_sk_your-account-api-key
BUTTERBASE_APP_ID=app_your-gateway-app-id
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_SERVICE_KEY=bb_sk_your-service-key
BUTTERBASE_MCP_URL=https://api.butterbase.ai/mcp
P2R_BUTTERBASE_APP_ID=app_your-paper2result-app-id

# RocketRide — local engine
PIPELINE_URL=http://localhost:5565/webhook
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=your-rocketride-api-key

# Pipeline variable substitution (${ROCKETRIDE_*} in .pipe files)
# LLM via Butterbase AI gateway (OpenAI-compatible; powers extraction,
# codegen, and the agent pipeline — no separate OpenAI key needed)
ROCKETRIDE_GATEWAY_BASE_URL=https://api.butterbase.ai/v1/<your-app-id>
ROCKETRIDE_GATEWAY_KEY=your-butterbase-service-key
ROCKETRIDE_GATEWAY_MODEL=anthropic/claude-sonnet-4.5
ROCKETRIDE_NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
ROCKETRIDE_NEO4J_USER=neo4j
ROCKETRIDE_NEO4J_PASSWORD=your-neo4j-password

# Daytona sandbox execution
DAYTONA_API_KEY=dtn_your-daytona-key

# Direct LLM keys — optional fallback (gateway is preferred)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
