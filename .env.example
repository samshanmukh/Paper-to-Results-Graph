# Neo4j Aura
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# Butterbase (account API key + apps)
BUTTERBASE_API_KEY=bb_sk_your-account-api-key
BUTTERBASE_API_URL=https://api.butterbase.ai
P2R_BUTTERBASE_APP_ID=app_your-paper2result-app-id
# Protects /admin visitor data. Use a random value of at least 16 characters.
ADMIN_TRACKING_KEY=replace-with-a-long-random-secret

# Protected FastAPI operations (upload/run/reset/workspace/agents).
# Use 32+ random characters. Remote mutation access is denied without this key.
VERIGRAPH_API_KEY=replace-with-at-least-32-random-characters
# Lets only a direct, non-browser loopback client call exact /api/run/<method_id>
# paths without exposing an API credential to the RocketRide agent or LLM.
VERIGRAPH_ENABLE_ROCKETRIDE_EXECUTOR=false
# Keep disabled by default. Opt in only for a directly accessed local demo.
VERIGRAPH_ALLOW_LOCAL_MUTATIONS=false
VERIGRAPH_RATE_LIMIT_DEFAULT=120
VERIGRAPH_RATE_LIMIT_EXECUTION=5
VERIGRAPH_RATE_LIMIT_INGESTION=5
VERIGRAPH_RATE_LIMIT_AGENT=20
VERIGRAPH_MAX_REQUEST_BYTES=26000000
VERIGRAPH_MAX_CONCURRENT_RUNS=2
VERIGRAPH_MAX_CONCURRENT_INGESTS=1
VERIGRAPH_MAX_ACTIVE_PAPERS=50
# Ownership boundary for Verigraph nodes in a shared Neo4j database.
VERIGRAPH_GRAPH_NAMESPACE=verigraph
# Deterministic Neo4j-grounded responses are the secure default.
GROUNDED_AGENTS=true

# RocketRide — local engine
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=MYAPIKEY

# Pipeline variable substitution (${ROCKETRIDE_*} in .pipe files)
# LLM via Butterbase AI gateway (OpenAI-compatible; powers extraction,
# codegen, and the agent pipeline)
ROCKETRIDE_GATEWAY_BASE_URL=https://api.butterbase.ai/v1/<your-app-id>
ROCKETRIDE_GATEWAY_KEY=your-butterbase-service-key
ROCKETRIDE_GATEWAY_MODEL=x-ai/grok-4.3
ROCKETRIDE_NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
ROCKETRIDE_NEO4J_DATABASE=neo4j
ROCKETRIDE_GRAPH_NAMESPACE=verigraph
# Opt in only with a separate Neo4j account that has database reader privileges.
# Verigraph probes this identity and refuses it if any mutation succeeds.
VERIGRAPH_ENABLE_ROCKETRIDE_DB=false
ROCKETRIDE_NEO4J_READONLY_USER=verigraph_reader
ROCKETRIDE_NEO4J_READONLY_PASSWORD=your-read-only-neo4j-password

# Daytona sandbox execution
DAYTONA_API_KEY=dtn_your-daytona-key

# Bright Data — optional Web Unlocker fallback for arXiv / paper URL fetch
BRIGHTDATA_API_TOKEN=your-brightdata-api-token
# BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker   # only if your account uses a custom zone name
# BRIGHTDATA_DISABLED=1                       # set to skip Bright Data even when token is present

# Cognee semantic memory (optional — indexes paper text + run logs for recall)
COGNEE_ENABLED=false

# Cognee Cloud — Sessions + Brain on platform.cognee.ai (from API Keys page)
# COGNEE_CLOUD=true
# COGNEE_SERVICE_URL=https://your-tenant.aws.cognee.ai
# COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
# COGNEE_API_KEY=ck_your-cognee-cloud-api-key
# COGNEE_SESSION_ID=verigraph-cloud-demo
# COGNEE_DATASET=default_dataset

# Cognee local mode — storage in .cognee/, fastembed + Butterbase gateway LLM
# COGNEE_CLOUD=false
# COGNEE_DATASET=verigraph
# COGNEE_EMBEDDING_PROVIDER=fastembed
# COGNEE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# COGNEE_EMBEDDING_DIMENSIONS=384
# COGNEE_LOG_LEVEL=ERROR
